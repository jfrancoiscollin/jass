# Per-job internals — not committed.
# Only status.json, output.log (truncated tail) and artefacts/ get
# committed by the runner. Everything else stays on the server.
results/*/output.log.raw
results/*/exit_code
results/*/artefacts.src/

# The repo-root .gitignore has `*.log`, which would also swallow the
# runner's output.log and any *.log files the job places in artefacts/.
# Re-include them here so reap commits actually carry the logs.
!results/*/output.log
!results/*/artefacts/*.log
